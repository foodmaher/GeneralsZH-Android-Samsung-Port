<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Vulkan is the entire render path (D3D8 -> DXVK -> Vulkan); refuse to
         install on devices without a Vulkan 1.1 driver. DXVK 2.6 itself needs
         Vulkan 1.3 at runtime — checked with a readable error at startup
         rather than a market filter, so Mali-1.1 devices can still run a
         future fallback renderer build. -->
    <uses-feature
        android:name="android.hardware.vulkan.version"
        android:version="0x401000"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="true" />

    <!-- GeneralsX @build Android port 07/07/2026 "All files access": lets the
         in-app folder browser (FolderPickerActivity) resolve to a real
         filesystem path anywhere in shared storage (Downloads, an SD card,
         wherever the user already has the game files) — no adb push, no
         restrictive per-folder scoped-storage grants. tools:ignore silences
         the Play-policy lint warning; this APK is sideloaded, not
         Play-distributed, so that policy does not apply. -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="true"
        android:isGame="true"
        android:appCategory="game"
        android:hardwareAccelerated="true"
        android:requestLegacyExternalStorage="false">

        <activity
            android:name=".GeneralsZHActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:launchMode="singleInstance"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen"
            android:preferMinimalPostProcessing="true"
            android:configChanges="layoutDirection|locale|orientation|uiMode|screenLayout|screenSize|smallestScreenSize|keyboard|keyboardHidden|navigation">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- GeneralsX @build Android port 07/07/2026 A second, always-present
             launcher icon: configuring the game folder or reading a crash log
             must never depend on the game itself having launched successfully.

             GeneralsX @bugfix Android port 07/07/2026 Locked to the same
             absolute "landscape" as GeneralsZHActivity (was unspecified, i.e.
             portrait-first): a real-device log caught the game's D3D device
             creation reading a portrait window size (1156x2510 instead of
             the correct 2510x1156) because Setup -> Launch Game triggered a
             portrait->landscape rotation that hadn't finished settling by
             the time WW3D::Init() queried the window size a few seconds
             later. Keeping both activities landscape the whole time removes
             the rotation — and the race — entirely. GeneralsZHActivity was
             also switched here from sensorLandscape (accelerometer-based) to
             plain landscape: sensorLandscape is what actually produced the
             race, since it can take a moment to settle instead of applying
             immediately like a plain absolute orientation. -->
        <activity
            android:name=".SetupActivity"
            android:exported="true"
            android:label="GeneralsZH Setup"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".FolderPickerActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <activity
            android:name=".LogViewerActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden" />
    </application>
</manifest>
